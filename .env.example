# Used for local Edge Function testing.
# Hosted Supabase Edge Functions receive SUPABASE_URL and SUPABASE_PUBLISHABLE_KEYS automatically.
APP_SUPABASE_URL=https://your-project-ref.supabase.co
APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Older Supabase projects may still use an anon key name.
# The Edge Function also supports APP_SUPABASE_ANON_KEY for local testing.
APP_SUPABASE_ANON_KEY=your_anon_key_here
